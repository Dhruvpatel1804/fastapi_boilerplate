# postgres creds
ASYNC_DATABASE_URL="postgresql+asyncpg://{DB_USER}:{DB_PASSWORD}@{DB_SERVER}:{DB_PORT}/{DB_NAME}"

# jwt creds
SECRET_KEY=secretkeyvalue
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Worker / broker
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
HEALTHCHECK_INTERVAL_SECONDS=3600